# Nginx 配置示例
# 适用于路径: wjlpt.com/change-major

location /change-major/ {
    # 重要：设置上传文件大小限制为 16MB
    client_max_body_size 16M;

    # 上传超时设置
    proxy_read_timeout 300;
    proxy_connect_timeout 300;
    proxy_send_timeout 300;

    # 去掉 /change-major 前缀，转发到本地 5002 端口
    # 例如: /change-major/api/upload/file -> http://127.0.0.1:5002/api/upload/file
    rewrite ^/change-major/(.*) /$1 break;
    proxy_pass http://127.0.0.1:5002;

    # 请求头设置
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 如果后端返回错误，不要拦截
    proxy_intercept_errors off;
}

# 或者使用这种方式（推荐）
location /change-major {
    client_max_body_size 16M;
    proxy_read_timeout 300;
    proxy_connect_timeout 300;
    proxy_send_timeout 300;

    # 使用 proxy_pass 末尾加 / 的方式自动去掉前缀
    # /change-major/api/upload/file -> http://127.0.0.1:5002/api/upload/file
    proxy_pass http://127.0.0.1:5002/;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_intercept_errors off;
}
